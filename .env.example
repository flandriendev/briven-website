# Briven.ai Environment Variables
# Copy this to .env.local and fill in real values

# ─── Convex ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=https://aware-ladybug-739.convex.cloud

# ─── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key_here

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://briven.ai

# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=dev:aware-ladybug-739 # team: flndrn, project: briven

NEXT_PUBLIC_CONVEX_SITE_URL=https://aware-ladybug-739.convex.site
