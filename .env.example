# Briven.ai Environment Variables
# Copy this to .env.local and fill in real values

# ─── Convex ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=https://adorable-jay-502.convex.cloud

# ─── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key_here

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://briven.ai

# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=dev:adorable-jay-502 # team: flandriendev, project: briven

NEXT_PUBLIC_CONVEX_SITE_URL=https://adorable-jay-502.convex.site
